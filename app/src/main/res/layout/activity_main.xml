<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/card_light">

    <!-- Tab layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/tg_blue"
        app:tabTextColor="@color/white"
        app:tabIndicatorColor="@color/white" />

    <!-- Proxy tab container -->
    <LinearLayout
        android:id="@+id/proxyTab"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header row: help + update + language -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/helpButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/btn_help"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:icon="@drawable/ic_help"
                app:iconSize="18dp"
                app:iconPadding="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/checkUpdateButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/btn_check_update"
                android:textAllCaps="false"
                android:textSize="13sp"
                app:icon="@drawable/ic_refresh"
                app:iconSize="18dp"
                app:iconPadding="4dp" />
        </LinearLayout>

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/statusIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_proxy_off"
                android:contentDescription="@string/proxy_status" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary_light" />
            </LinearLayout>
        </LinearLayout>

        <!-- Language selector REMOVED from here; moved to Enhanced Settings card -->

        <!-- Toggle button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/toggleButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_enable"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="12dp" />

        <!-- Telegram link button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openTelegramButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/open_telegram"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="12dp" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Host -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_host"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/hostInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Port -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_port"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/portInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Secret -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_secret"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/secretInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textNoSuggestions"
                        android:fontFamily="monospace"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/regenSecretButton"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/regen_secret"
                    android:textAllCaps="false"
                    android:layout_marginBottom="8dp" />

                <!-- DC IPs -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_dc_ip"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/dcInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:maxLines="6"
                        android:fontFamily="monospace" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Fake TLS domain -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_fake_tls"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/fakeTlsInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Pool size -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_pool_size"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/poolSizeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Enhanced settings card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/field_border"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_enhanced_settings"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <!-- Language setting -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/settings_language"
                                android:textSize="14sp" />

                            <Spinner
                                android:id="@+id/languageSpinner"
                                android:layout_width="120dp"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/checkUpdatesSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_auto_check_updates"
                            android:checked="true"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/useDoHSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_doh"
                            android:checked="true"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/autoFakeTlsSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_auto_fake_tls"
                            android:checked="true"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/parallelConnectSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_parallel"
                            android:checked="true"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/mediaViaCfSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_media_cf"
                            android:checked="false"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/cfproxySwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_cf_proxy"
                            android:checked="true"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/cfproxyPrioritySwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_cf_priority"
                            android:checked="true"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/wsPaddingSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_ws_padding"
                            android:checked="false"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/dohRotationSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_doh_rotation"
                            android:checked="true"
                            android:layout_marginBottom="4dp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/workInBackgroundSwitch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/switch_background"
                            android:checked="false" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Save button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/btn_save"
                    android:textAllCaps="false"
                    android:layout_marginBottom="12dp"
                    app:cornerRadius="8dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/linkCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/field_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_link"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/linkText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textIsSelectable="true"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/copyLinkButton"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:text="@string/btn_copy"
                                android:textAllCaps="false"
                                android:textSize="16sp"
                                app:cornerRadius="8dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/field_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_stats"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:id="@+id/statsConnections"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/statsTraffic"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Logs tab container -->
    <LinearLayout
        android:id="@+id/logsTab"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefreshLogs"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_refresh"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearLogs"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_clear"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareLogs"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_share"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveLogs"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/btn_save"
                android:textAllCaps="false" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/logLevelChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:singleSelection="true"
            app:checkedChip="@id/chipInfo">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDebug"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_level_debug" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipInfo"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_level_info" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipWarn"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_level_warn" />
        </com.google.android.material.chip.ChipGroup>

        <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/black"
            android:padding="8dp">

            <TextView
                android:id="@+id/logTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@android:color/holo_green_light"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>
